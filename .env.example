# ============================================
# Portfolio — Environment Variables Reference
# ============================================
# Copy to .env.local and fill in values

NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=Your Name
NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/yourusername
NEXT_PUBLIC_TWITTER_URL=

PAYLOAD_SECRET=your-random-secret-here
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/portfolio
# SQLite fallback for local-only development:
# DATABASE_URI=file:./data.db
PAYLOAD_URL=https://yourdomain.com

# Optional: email via Resend
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_EMAIL=hello@yourdomain.com
